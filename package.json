{
  "name": "content-island-static-snapshot",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @app/api & npm run dev -w @app/web",
    "dev:web": "npm run dev -w @app/web",
    "dev:api": "npm run dev -w @app/api",
    "build": "npm run build --workspaces --if-present",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5"
  }
}
