{
  "name": "@app/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js",
    "start": "node dist/server.js",
    "snapshot:export": "content-island export --access-token \"$CONTENT_ISLAND_READ_TOKEN\" --snapshot-path content-island-snapshot.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@content-island/api-client": "^0.24.0",
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.28"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.2"
  }
}
